# -------------------------
# Terraform directories
# -------------------------
.terraform/

# -------------------------
# State files (NEVER commit)
# -------------------------
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# -------------------------
# Terraform variables (sensitive)
# -------------------------
*.tfvars
*.tfvars.json

# -------------------------
# Plan files (optional outputs)
# -------------------------
*.tfplan

# -------------------------
# Crash logs
# -------------------------
crash.log
crash.*.log

# -------------------------
# CLI config files
# -------------------------
.terraformrc
terraform.rc

# -------------------------
# Override files
# -------------------------
override.tf
override.tf.json
*_override.tf
*_override.tf.json