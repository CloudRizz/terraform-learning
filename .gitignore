# Terraform working directories
.terraform/

# Terraform state files (VERY IMPORTANT)
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Crash logs
crash.log
crash.*.log

# CLI config files
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files (if you save plans)
*.tfplan